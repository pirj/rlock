#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
LIB_DIR="$PROJECT_DIR/lib"
export RL_LIB_DIR="$LIB_DIR"
export RL_BIN_DIR="$SCRIPT_DIR"

source "$LIB_DIR/ui.sh"
source "$LIB_DIR/util.sh"
source "$LIB_DIR/toml.sh"
source "$LIB_DIR/plugin.sh"
source "$LIB_DIR/snapshot.sh"

cmd_help() {
    cat <<'USAGE'
Usage: rl <command> [args...]

Commands:
  new [plugins...]   Create a new airlock VM
  rm                 Destroy the airlock VM
  status             Show airlock status
  ssh                SSH into the VM
  cache <sub>        Inspect the snapshot layer cache (sub: stats)
  help               Show this help

Plugins are activated during 'rl new'. Additional commands
are provided by activated plugins.
USAGE
}

cmd_new() {
    local -a requested=("$@")

    # Check base host deps
    check_dependency "aq" "Install from https://github.com/pirj/aq"
    check_dependency "ssh" "Install OpenSSH"

    # Discover available plugins
    local -a available
    mapfile -t available < <(discover_plugins)

    # If no plugins requested, detect triggers and prompt
    local _prompted=0
    if [[ ${#requested[@]} -eq 0 || ( ${#requested[@]} -eq 1 && -z "${requested[0]:-}" ) ]]; then
        requested=()
        _prompted=1
        local -a triggered
        mapfile -t triggered < <(detect_triggers "$(pwd)" "${available[@]}")
        local plugin
        for plugin in "${triggered[@]}"; do
            [[ -n "$plugin" ]] || continue
            local desc
            desc=$(toml_get "$(plugin_dir "$plugin")/plugin.toml" "description")
            local answer
            read -rp "Include ${desc:-$plugin}? (Y/n) " answer
            if [[ "${answer:-Y}" =~ ^[Yy]$ ]]; then
                requested+=("$plugin")
            fi
        done
    fi

    # Resolve dependencies
    local -a resolved=()
    if [[ ${#requested[@]} -gt 0 ]]; then
        mapfile -t resolved < <(resolve_deps "${requested[@]}")
    fi

    # Check for additional triggered plugins not yet in the resolved list
    # (only when plugins were explicitly requested via CLI args)
    if [[ ${#requested[@]} -gt 0 && ${#resolved[@]} -gt 0 && "$_prompted" != "1" ]]; then
        local -a extra_triggered
        export ACTIVATED_PLUGINS="${resolved[*]}"
        mapfile -t extra_triggered < <(detect_triggers "$(pwd)" "${available[@]}")
        local plugin
        for plugin in "${extra_triggered[@]}"; do
            [[ -n "$plugin" ]] || continue
            local desc
            desc=$(toml_get "$(plugin_dir "$plugin")/plugin.toml" "description")
            local answer
            read -rp "Include ${desc:-$plugin}? (Y/n) " answer
            if [[ "${answer:-Y}" =~ ^[Yy]$ ]]; then
                mapfile -t resolved < <(resolve_deps "${resolved[@]}" "$plugin")
            fi
        done
    fi

    # Check host deps, command conflicts, and protocol versions
    if [[ ${#resolved[@]} -gt 0 ]]; then
        check_protocol_versions "${resolved[@]}" || die "Plugin protocol incompatible."
        check_host_deps "${resolved[@]}"
        check_command_conflicts "${resolved[@]}"
    fi

    # Create VM
    local vm_name
    vm_name=$(get_vm_name)

    if [[ -d "$AQ_STATE_DIR/$vm_name" ]]; then
        die "Airlock '$vm_name' already exists. Run 'rl rm' first."
    fi

    # Compute the max RAM declared across active plugins (via the
    # [snapshot] memory = "NG" field). Plugins that need more than aq's
    # default 1G (notably docker-compose with kind = "live") declare
    # their need; the framework collects the max and passes it as
    # --memory=NG. Plugins that don't declare memory contribute nothing.
    local -a aq_new_args=("--size=16G")
    if [[ ${#resolved[@]} -gt 0 ]]; then
        local _max_mem
        _max_mem=$(max_snapshot_memory "${resolved[@]}")
        if [[ -n "$_max_mem" ]]; then
            aq_new_args+=("--memory=${_max_mem}G")
        fi
    fi

    spinner_start "Creating VM"
    aq new "${aq_new_args[@]}" "$vm_name"
    aq start "$vm_name"
    spinner_stop "VM created"

    save_vm_name "$vm_name"

    spinner_start "Waiting for SSH"
    if ! wait_for_ssh "$vm_name" 60; then
        die "SSH connection timed out"
    fi
    spinner_stop "SSH ready"

    # Walk the snapshot layer chain.
    # `_base` is always prepended: it's the framework-internal layer that
    # carries the apk-add / rlock-user / sshd-hardening provisioning shared
    # across every rlock distribution. After the first cold rl new on a
    # host, every subsequent cold (any distribution, any project) gets a
    # cache hit on _base instead of re-paying ~30 s of base provisioning.
    spinner_start "Walking snapshot layers"
    snapshot_walk_chain "$vm_name" "_base" "${resolved[@]}"
    spinner_stop "Layers ready"
    # Boot the VM back up after the chain leaves it stopped.
    aq start "$vm_name" >/dev/null
    wait_for_ssh "$vm_name" 60 >/dev/null

    # Run provision hooks for plugins WITHOUT [snapshot] (legacy + side-effect-only)
    local plugin
    for plugin in "${resolved[@]}"; do
        if plugin_has_snapshot "$plugin"; then
            continue
        fi
        spinner_start "Provisioning: $plugin"
        if ! run_hook "$plugin" "provision" "$vm_name"; then
            spinner_stop "FAILED: $plugin"
            die "Plugin '$plugin' provisioning failed. VM left for debugging (rl ssh to inspect, rl rm to clean up)."
        fi
        spinner_stop "Provisioned: $plugin"
    done

    # Run plugin start hooks
    for plugin in "${resolved[@]}"; do
        run_hook "$plugin" "start" "$vm_name" || true
    done

    # Save activated plugins
    if [[ ${#resolved[@]} -gt 0 ]]; then
        save_active_plugins "${resolved[@]}"
    fi

    success "Airlock ready"
    if [[ ${#resolved[@]} -gt 0 ]]; then
        info "Active plugins: ${resolved[*]}"
    fi

    # Surface the previous prune's result if any.
    local prune_log="${RL_CACHE_DIR:-${XDG_DATA_HOME:-$HOME/.local/share}/aq/cache}/.last-prune.log"
    if [[ -f "$prune_log" ]]; then
        info "$(cat "$prune_log")"
        rm -f "$prune_log"
    fi

    # Background prune: compute current live set from VM backing chains,
    # then drop stale cache entries.
    (
        live_args=()
        for d in "$AQ_STATE_DIR"/*/storage.qcow2; do
            [[ -f "$d" ]] || continue
            while IFS= read -r b; do
                [[ -n "$b" ]] && live_args+=("--live" "$b")
            done < <(qemu-img info --backing-chain "$d" 2>/dev/null \
                | sed -n 's/^backing file: //p')
        done
        snapshot_prune "${live_args[@]}"
    ) &
    disown
}

cmd_rm() {
    local vm_name
    vm_name=$(resolve_vm_name) || die "No airlock found in this directory"

    # Run rm hooks in reverse order
    local -a plugins
    mapfile -t plugins < <(get_active_plugins)
    local i
    for ((i=${#plugins[@]}-1; i>=0; i--)); do
        local plugin="${plugins[$i]}"
        [[ -n "$plugin" ]] || continue
        run_hook "$plugin" "rm" "$vm_name" || warn "Plugin '$plugin' cleanup failed"
    done

    # Destroy VM
    spinner_start "Destroying VM"
    aq rm "$vm_name" >/dev/null 2>&1 || warn "aq rm failed for '$vm_name'"
    spinner_stop "VM destroyed"

    rm -rf "$RL_DIR"
    success "Airlock removed"
}

cmd_status() {
    local vm_name
    vm_name=$(resolve_vm_name) || die "No airlock found in this directory"

    local state
    if is_vm_running "$vm_name"; then
        local pid port
        pid=$(<"$AQ_STATE_DIR/$vm_name/process.pid")
        port=$(get_ssh_port "$vm_name")
        state="${GREEN}running${RESET} (PID $pid, SSH port $port)"
    else
        state="${YELLOW}stopped${RESET}"
    fi

    echo "Airlock: $vm_name"
    echo "VM:      $state"

    local _plugins=()
    mapfile -t _plugins < <(get_active_plugins)
    if [[ ${#_plugins[@]} -gt 0 && -n "${_plugins[0]:-}" ]]; then
        echo "Plugins: ${_plugins[*]}"
    fi

    # Code state: compare local HEAD with rl remote (if both exist)
    if git rev-parse --is-inside-work-tree > /dev/null 2>&1 \
        && git remote get-url rl > /dev/null 2>&1; then
        local local_sha remote_sha
        local_sha=$(git rev-parse HEAD 2>/dev/null) || local_sha=""
        remote_sha=$(git ls-remote rl HEAD 2>/dev/null | awk '{print $1}') || remote_sha=""
        if [[ -n "$local_sha" && -n "$remote_sha" && "$local_sha" != "$remote_sha" ]]; then
            local ahead
            ahead=$(git rev-list --count "$remote_sha..$local_sha" 2>/dev/null) || ahead="?"
            echo "Code:    behind by $ahead commits (push: git push rl)"
        fi
    fi
}

cmd_ssh() {
    local vm_name
    vm_name=$(resolve_vm_name) || die "No airlock found in this directory"
    do_ssh "$vm_name"
}

# rl cache stats   — per-plugin hit/miss/rebuild-time table.
# Future: rl cache ls, rl cache rm <plugin>[:<key>] (today live in
# bakeri.sh's bake-cache; framework command exists only for the
# analytics surface).
cmd_cache() {
    local sub="${1:-stats}"
    case "$sub" in
        stats) snapshot_stats_show ;;
        ""|help|-h|--help)
            cat <<'EOF'
Usage: rl cache <subcommand>

Subcommands:
  stats     Per-plugin hits / misses / hit rate / avg rebuild time.
EOF
            ;;
        *) die "Unknown subcommand: rl cache $sub" ;;
    esac
}

# Main dispatch
case "${1:-help}" in
    new)    shift; cmd_new "$@" ;;
    rm)     cmd_rm ;;
    status) cmd_status ;;
    ssh)    cmd_ssh ;;
    cache)  shift; cmd_cache "$@" ;;
    help|--help|-h) cmd_help ;;
    *)
        # Try plugin command dispatch.
        # Read plugins without process substitution to preserve stdin (terminal).
        _active_plugins=""
        if [[ -f "$RL_DIR/plugins" ]]; then
            _active_plugins=$(tr '\n' ' ' < "$RL_DIR/plugins")
        fi
        if [[ -n "$_active_plugins" ]]; then
            ACTIVE_PLUGINS="$_active_plugins" dispatch_command "$@"
        else
            die "Unknown command: $1. Run 'rl help' for usage."
        fi
        ;;
esac
